# ---------------------------------------------------------------------------
# OpenRouter  (Shivani's brain)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...
# Any tool-calling model slug from https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Control  (who may command Shivani over WhatsApp)
# ---------------------------------------------------------------------------
# ONLY this number controls the agent. Country code first, no + or spaces.
OPERATOR_JIDS=917899452307

# ---------------------------------------------------------------------------
# Identity + knowledge
# ---------------------------------------------------------------------------
AGENT_NAME=Shivani
COMPANY_NAME=ACRED
KB_PATH=./knowledge/acred-kb.md

# ---------------------------------------------------------------------------
# Founders & cadence  (fill in, then flip ENABLE_CADENCE=true)
# ---------------------------------------------------------------------------
# "Name:number,Name:number" — lets tools target a founder by name.
FOUNDERS=Yuvaraj:917899452307,Charu:,Prajwal:,Ops:
# Founders' WhatsApp group JID (looks like 1203630xxxxxxxxxx@g.us). Leave blank until known.
FOUNDERS_GROUP_JID=
# Weekly digest recipient (defaults to the operator if blank).
CEO_JID=917899452307
# Proactive rhythm. Keep false until founder numbers/group are set.
ENABLE_CADENCE=false
CHECKIN_CRON=0 9,13,17,21 * * *
DIGEST_CRON=0 18 * * 5

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
DATA_DIR=./data
MAX_AGENT_STEPS=25
SHELL_TIMEOUT_MS=120000
APP_TITLE=ACRED Shivani
APP_URL=https://acred.in
TZ=Asia/Kolkata
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn

# ---------------------------------------------------------------------------
# Super-memory  (Postgres + pgvector long-term brain)
# ---------------------------------------------------------------------------
# Unset => remember_fact/search_memory return "not configured: set DATABASE_URL"
# and the app still boots on SQLite alone. Needs the pgvector extension.
DATABASE_URL=

# Embeddings (any OpenAI-compatible /embeddings endpoint). Unset => semantic
# recall falls back to ILIKE keyword search.
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
# 1536 dims, matching the memories.embedding pgvector column.
EMBEDDINGS_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Self-evolution  (skills, plugins, self-deploy, watchdog)
# ---------------------------------------------------------------------------
# Repo root for git+build and to resolve ./skills, ./plugins, ./data. Defaults
# to process.cwd() (the systemd WorkingDirectory).
REPO_ROOT=/opt/cos-agent
SKILLS_DIR=skills
PLUGINS_DIR=plugins
# App entry the watchdog launches/supervises.
WATCHDOG_ENTRY=dist/index.js
# ms a restarted child must stay up to count as healthy before snapshotting last-good.
HEALTH_WINDOW_MS=20000
# If set, self_diagnose tails the last 30 lines of this file (else stdout/journald).
SHIVANI_LOG_FILE=

# ---------------------------------------------------------------------------
# Web browsing  (real headless Chromium — no API keys, no cost)
# ---------------------------------------------------------------------------
# web_search / web_read drive a real Chromium (DuckDuckGo, Bing fallback). No key.
# The installer sets this so the service user can find Puppeteer's Chromium:
PUPPETEER_CACHE_DIR=
# Or point at a system Chromium instead of the bundled one:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ---------------------------------------------------------------------------
# Gmail  (OAuth; alt: connectors row name='gmail'. Tools inert until set)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional short-lived token; client needs client_id+secret AND (refresh OR access) token.
GOOGLE_ACCESS_TOKEN=
# Only for Web-application OAuth clients.
GOOGLE_REDIRECT_URI=

# ---------------------------------------------------------------------------
# Notion  (internal integration secret; alt: connectors row name='notion')
# ---------------------------------------------------------------------------
NOTION_TOKEN=

# ---------------------------------------------------------------------------
# WhatsApp outbound pacing  (ban-avoidance; safe defaults)
# ---------------------------------------------------------------------------
# Minimum ms between two outbound sends.
WA_MIN_GAP_MS=4000
# Max sends in any rolling 60-minute window.
WA_MAX_PER_HOUR=60
# Extra random 0..N ms per gap so traffic is not metronomic.
WA_JITTER_MS=2000

# ---------------------------------------------------------------------------
# Group participation + collaborate tier
# ---------------------------------------------------------------------------
# Extra group JIDs (comma-separated) she participates in, besides FOUNDERS_GROUP_JID.
GROUP_ALLOWLIST=
# Reply to non-operator DMs (collaborate tier). false => ignore strangers who DM.
REPLY_TO_ANYONE=true
# In a group, stay quiet for this long after her own reply (unless addressed by name).
GROUP_COOLDOWN_MS=45000
# Max group replies in any rolling hour (unless addressed by name).
GROUP_MAX_PER_HOUR=12
# Optional cheaper model for the "should I speak?" triage. Empty => main model.
GROUP_TRIAGE_MODEL=
# Optional model for spawned sub-agents (Increment 2). Empty => main model.
SUBAGENT_MODEL=

# ---------------------------------------------------------------------------
# Escalation  (overdue-commitment sweep)
# ---------------------------------------------------------------------------
# SLA in whole days for open commitments/tasks that carry no deadline — anything
# open longer than this counts as slipping. Optional; defaults to 3. Overridable
# per-call via the sla_days tool arg.
ESCALATION_SLA_DAYS=3

# ---------------------------------------------------------------------------
# acred OS  (Supabase READ connector for live internal numbers)
# ---------------------------------------------------------------------------
# acred OS (Supabase) project URL for the READ connector. Unset => acredos tools
# return 'acred OS not connected'.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Supabase service-role key for server-side reads of acred OS internal data.
# Unset => acredos tools return 'acred OS not connected'.
SUPABASE_SERVICE_KEY=eyJhbGciOi...service_role_key
